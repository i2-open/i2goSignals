# Used to configure SsfServer in docker and IDE

DBNAME=SsfServer1
PORT=8890
BASE_URL=http://localhost:8890/
OAUTH_SERVERS=http://keycloak:8080/realms/gosignals/.well-known/openid-configuration
KEYCLOAK_URL=https://keycloak:8080/realms/gosignals
MEM_DIRECTORY=/app/config/SsfServer1
MEM_SAVE_RATE=30
LOG_LEVEL=DEBUG

TLS_ENABLED=true
SERVER_CERT_PATH=/app/config/certs/server-cert.pem
SERVER_KEY_PATH=/app/config/certs/server-key.pem
CA_CERT=/app/config/certs/ca-cert.pem