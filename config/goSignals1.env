# Used to configure GoSignals1 in docker and IDE

MONGO_URL=mongodb://root:dockTest@mongo1:30001,mongo2:30002,mongo3:30003/?retryWrites=true&replicaSet=dbrs&readPreference=primary&serverSelectionTimeoutMS=5000&connectTimeoutMS=10000&authSource=admin&authMechanism=SCRAM-SHA-256
I2SIG_STORE_MONGO_DBNAME=goSignals1
PORT=8888
BASE_URL=https://goSignals1:8888/
I2SIG_AUTH_OAUTH_SERVERS=https://keycloak:9080/realms/gosignals/.well-known/openid-configuration

ADMIN_PORT=8899
ADMIN_UI_DIR=/Users/pjdhunt/git/i2goSignals/adminUI/build

# Used in demo adminUI
KEYCLOAK_URL=https://keycloak:9080/realms/gosignals

I2SIG_STORE_MONGO_RESUME_FILE=/app/resources/mongo_token_1.json

LOG_LEVEL=DEBUG

I2SIG_TLS_ENABLED=true
I2SIG_TLS_CERT_PATH=/app/config/certs/server-cert.pem
I2SIG_TLS_KEY_PATH=/app/config/certs/server-key.pem
I2SIG_TLS_CA_CERT=/app/config/certs/ca-cert.pem

I2SIG_ISSUER_DEFAULT=https://gosignals1:8888