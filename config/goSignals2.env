  # Used to configure GoSignals2 in docker and IDE
  MONGO_URL=mongodb://root:dockTest@mongo1:30001,mongo2:30002,mongo3:30003/?retryWrites=true&replicaSet=dbrs&readPreference=primary&serverSelectionTimeoutMS=5000&connectTimeoutMS=10000&authSource=admin&authMechanism=SCRAM-SHA-256
  DBNAME=goSignals2
  PORT=8889
  BASE_URL=http://goSignals2:8889/
  OAUTH_SERVERS=http://keycloak:9080/realms/gosignals/.well-known/openid-configuration

  KEYCLOAK_URL=https://keycloak:9080/realms/gosignals

  MONGO_WATCH_FILE=/app/resources/mongo_token_2.json

  LOG_LEVEL=DEBUG

  TLS_ENABLED=true
  SERVER_CERT_PATH=/app/config/certs/server-cert.pem
  SERVER_KEY_PATH=/app/config/certs/server-key.pem
  CA_CERT=/app/config/certs/ca-cert.pem