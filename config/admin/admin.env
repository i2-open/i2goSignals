# Admin Server
PORT=8080

# Optional single upstream fallback for proxying when alias is not used
SIGNALS_UPSTREAM_BASE_URL=

# Auth (JWT validation) — values live below under `export AUTH_ISSUER/...`
# Comma-separated list, e.g. "admin:read,admin:write"
AUTH_REQUIRED_SCOPES=

# MongoDB persistence for server registry (optional)
MONGO_URL=mongodb://root:dockTest@mongo1:30001,mongo2:30002,mongo3:30003/?retryWrites=true&replicaSet=dbrs&readPreference=primary&serverSelectionTimeoutMS=5000&connectTimeoutMS=10000&authSource=admin&authMechanism=SCRAM-SHA-256
MONGO_DBNAME=gosignalsadmin



# Native OIDC login — the Go server serves /api/auth/* itself (no Auth.js).
# The adminui client must register redirect URI <base>/api/auth/callback;
# the gosignals realm client registers http://localhost:8899/* which covers it.
export AUTH_ISSUER=https://keycloak:9080/realms/gosignals
export AUTH_JWKS_URL=https://keycloak:9080/realms/gosignals/protocol/openid-connect/certs
export AUTH_AUDIENCE=adminui
export AUTH_CLIENT_ID=adminui
# Public (PKCE-only) client — leave the secret blank.
export AUTH_CLIENT_SECRET=

# Upstream is used for testing proxy purposes only ??
export SIGNALS_UPSTREAM_BASE_URL=https://gosignals1:8888
# Secret used by Auth.js to sign/encrypt cookies/JWTs
export AUTH_SECRET=dev_secret_change_me

export STS_CLIENT_ID=goSignalsAdminService
export STS_CLIENT_SECRET=admin-service-secret
export STS_TOKEN_URL=https://keycloak:9080/realms/gosignals/protocol/openid-connect/token

export AUTH_DEBUG=on

# Custom CA cert — Go reads as AuthCACert; Node maps to NODE_EXTRA_CA_CERTS via server/auth.ts
export AUTH_CA_CERT=/app/certs/ca-cert.pem

# Prometheus integration for the configurable Fleet Overview dashboard.
# When PROMETHEUS_URL is set, /api/admin/prom/query{,_range} proxy to the
# upstream Prometheus HTTP API. When unset, those endpoints return 503
# {configured:false} and the dashboard shows a friendly stub.
PROMETHEUS_URL=https://prometheus:9090
# Optional bearer token forwarded to upstream as Authorization: Bearer ...
# PROMETHEUS_AUTH_TOKEN=
# Set true to skip upstream TLS certificate verification (dev/self-signed only).
# PROMETHEUS_TLS_INSECURE_SKIP_VERIFY=false

# PRD-49: Logs scene backend
LOG_BACKEND_DEFAULT_TYPE=loki
LOG_BACKEND_DEFAULT_URL=http://loki:3100

# Enable TLS Mode
TLS_CERT_FILE=/app/certs/server-cert.pem
TLS_KEY_FILE=/app/certs/server-key.pem