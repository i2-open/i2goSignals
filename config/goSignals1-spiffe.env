# SPIFFE-enabled configuration for GoSignals1
MONGO_URL=mongodb://mongo1:30001,mongo2:30002,mongo3:30003/?tls=true&replicaSet=dbrs&authMechanism=MONGODB-X509&authSource=$$external
DBNAME=goSignals1
PORT=8888
BASE_URL=https://goSignals1:8888/
OAUTH_SERVERS=https://keycloak:9080/realms/gosignals/.well-known/openid-configuration
ADMIN_PORT=8899
ADMIN_UI_DIR=/app/adminUI/build
KEYCLOAK_URL=https://keycloak:9080/realms/gosignals
MONGO_WATCH_FILE=/app/resources/mongo_token_1.json
LOG_LEVEL=DEBUG
MONGO_BACKGROUND_RECONNECT=true
TLS_ENABLED=true
SERVER_CERT_PATH=/app/config/certs/server-cert.pem
SERVER_KEY_PATH=/app/config/certs/server-key.pem
CA_CERT=/app/config/certs/ca-cert.pem
I2SIG_ISSUER=https://gosignals1:8888
